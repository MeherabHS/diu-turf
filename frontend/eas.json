{
  "cli": {
    "version": ">= 13.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=arm64-v8a,armeabi-v7a -Pandroid.enableAbiSplits=true"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://diu-turf.onrender.com",
        "EXPO_PUBLIC_DEV_AUTH_ENABLED": "false",
        "EXPO_PUBLIC_SENTRY_DSN": ""
      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=arm64-v8a,armeabi-v7a -Pandroid.enableAbiSplits=true"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://diu-turf.onrender.com",
        "EXPO_PUBLIC_DEV_AUTH_ENABLED": "false",
        "EXPO_PUBLIC_SENTRY_DSN": ""
      }
    }
  }
}
